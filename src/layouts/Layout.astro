---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileBottomCTA from '../components/MobileBottomCTA.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Solviro Legal — Kancelaria specjalizująca się w restrukturyzacjach i upadłościach' } = Astro.props;
const siteUrl = Astro.site ?? new URL('https://solviro.pl');
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
---

<!DOCTYPE html>
<html lang="pl" data-theme="warm">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Google Fonts - DM Sans + Source Sans 3 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Source+Sans+3:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LegalService",
        "name": "Solviro Legal",
        "description": "Kancelaria specjalizująca się w restrukturyzacjach i upadłościach",
        "areaServed": "Polska",
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "name": "Restrukturyzacja" }},
            { "@type": "Offer", "itemOffered": { "name": "Upadłość" }}
          ]
        }
      }
    </script>
  </head>
  <body class="font-body antialiased" style="color: var(--color-text); background-color: var(--color-bg);">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <MobileBottomCTA />

    <!-- Theme Switcher (dev only) -->
     <div id="theme-switcher" class="theme-switcher">
  <button data-theme="warm">Warm</button>
  <button data-theme="coffee">Coffee</button>
  <button data-theme="sunset">Sunset</button>
  <button data-theme="luxury">Luxury</button>
  <button data-theme="olive">Olive</button>
  <button data-theme="forest">Forest</button>
  <button data-theme="slate">Slate</button>
</div>

    <script>
      const header = document.getElementById('main-header');

      const handleScroll = () => {
        if (window.scrollY > 50) {
          header?.classList.add('scrolled');
        } else {
          header?.classList.remove('scrolled');
        }
      };

      window.addEventListener('scroll', handleScroll, { passive: true });
      handleScroll();

      // Theme switcher (only visible with ?preview=1)
      const themeSwitcher = document.getElementById('theme-switcher');
      const urlParams = new URLSearchParams(window.location.search);
      
      if (urlParams.get('preview') === '1' && themeSwitcher) {
        themeSwitcher.classList.add('visible');
        
        const buttons = themeSwitcher.querySelectorAll('button');
        const currentTheme = document.documentElement.getAttribute('data-theme') || 'warm';
        
        buttons.forEach(btn => {
          if (btn.getAttribute('data-theme') === currentTheme) {
            btn.classList.add('active');
          }
          
          btn.addEventListener('click', () => {
            const theme = btn.getAttribute('data-theme');
            document.documentElement.setAttribute('data-theme', theme || 'warm');
            buttons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
          });
        });
      }
    </script>
  </body>
</html>

