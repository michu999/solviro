---
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '/', label: 'Strona główna' },
  { href: '/o-nas', label: 'O nas' },
  { href: '/restrukturyzacja', label: 'Restrukturyzacja' },
  { href: '/upadlosc', label: 'Upadłość' },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<footer class="bg-gray-900 text-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main Footer Content -->
    <div class="py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-6">
          <span class="font-heading text-2xl font-bold">
            Solviro<span class="text-gold">.</span>
          </span>
        </a>
        <p class="text-white/70 text-sm leading-relaxed mb-6">
          Kancelaria specjalizująca się w restrukturyzacjach i upadłościach. Pomagamy firmom wyjść z kryzysu finansowego.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-heading text-lg font-semibold mb-6">Nawigacja</h3>
        <ul class="space-y-3">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-white/70 hover:text-gold text-sm transition-colors duration-300"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-heading text-lg font-semibold mb-6">Usługi</h3>
        <ul class="space-y-3">
          <li>
            <a href="/restrukturyzacja" class="text-white/70 hover:text-gold text-sm transition-colors duration-300">
              Postępowanie restrukturyzacyjne
            </a>
          </li>
          <li>
            <a href="/upadlosc" class="text-white/70 hover:text-gold text-sm transition-colors duration-300">
              Upadłość firmy
            </a>
          </li>
          <li>
            <a href="/upadlosc" class="text-white/70 hover:text-gold text-sm transition-colors duration-300">
              Upadłość konsumencka
            </a>
          </li>
          <li>
            <a href="/restrukturyzacja" class="text-white/70 hover:text-gold text-sm transition-colors duration-300">
              Układ z wierzycielami
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading text-lg font-semibold mb-6">Kontakt</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-white/70 text-sm">
              ul. Przykładowa 123<br />
              00-001 Warszawa
            </span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+48123456789" class="text-white/70 hover:text-gold text-sm transition-colors duration-300">
              +48 123 456 789
            </a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:kontakt@solviro.pl" class="text-white/70 hover:text-gold text-sm transition-colors duration-300">
              kontakt@solviro.pl
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/10 py-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-white/50 text-sm">
          © {currentYear} Solviro Legal. Wszelkie prawa zastrzeżone.
        </p>
        <div class="text-white/50 text-sm">
          <span>NIP: 000-000-00-00</span>
          <span class="mx-3">|</span>
          <span>KRS: 0000000000</span>
        </div>
      </div>
    </div>
  </div>
</footer>

