---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
import { getCaseStudies } from '../lib/sanity';

const caseStudies = await getCaseStudies();
---

<Layout title="Case Studies — Solviro Legal" description="Poznaj nasze realizacje. Zobacz, jak pomogliśmy firmom w procesach restrukturyzacji i upadłości.">
  
  <PageHero
    title="Nasze realizacje"
    description="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    breadcrumb={[
      { label: 'Strona główna', href: '/' },
      { label: 'Case Studies', href: '/case-studies' }
    ]}
  />

  <!-- Case Studies Grid -->
  <section class="py-20 sm:py-28" style="background-color: var(--color-bg);">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {caseStudies.map((caseStudy) => (
          <article class="rounded-lg overflow-hidden hover:shadow-md transition-shadow duration-300" style="background-color: var(--color-bg-subtle);">
            <div class="h-48" style="background-color: var(--color-text-muted); opacity: 0.2;"></div>
            <div class="p-8">
              <span
                class="inline-block text-sm font-medium px-3 py-1 rounded-full mb-4"
                style="background-color: var(--color-accent); color: var(--color-text);"
              >
                {caseStudy.industry}
              </span>
              <h2 class="font-heading text-xl font-bold mb-3" style="color: var(--color-text);">
                {caseStudy.title}
              </h2>
              <p class="text-sm leading-relaxed mb-6 line-clamp-3" style="color: var(--color-text-muted);">
                {caseStudy.challenge.substring(0, 150)}...
              </p>
              <div class="flex items-center justify-between pt-6 border-t" style="border-color: var(--color-text-muted);">
                <span class="text-sm font-medium" style="color: var(--color-accent);">{caseStudy.result}</span>
                <a
                  href={`/case-studies/${caseStudy.slug}`}
                  class="inline-flex items-center gap-1 font-semibold text-sm transition-all duration-300 hover:gap-2"
                  style="color: var(--color-text);"
                >
                  Czytaj więcej
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection variant="dark" />

</Layout>
