---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="Upadłość — Solviro Legal" description="Profesjonalne wsparcie w postępowaniach upadłościowych. Upadłość firmy i upadłość konsumencka.">
  
  <PageHero 
    title="Upadłość"
    description="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris."
    breadcrumb={[
      { label: 'Strona główna', href: '/' },
      { label: 'Upadłość', href: '/upadlosc' }
    ]}
  />

  <!-- What is Bankruptcy -->
  <section class="py-20 sm:py-28" style="background-color: var(--color-bg);">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <span class="inline-block font-semibold text-sm uppercase tracking-wider mb-4" style="color: var(--color-accent);">Czym jest</span>
          <h2 class="font-heading text-3xl sm:text-4xl font-bold mb-6" style="color: var(--color-text);">
            Postępowanie upadłościowe
          </h2>
          <p class="leading-relaxed mb-6" style="color: var(--color-text-muted);">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
          </p>
          <p class="leading-relaxed" style="color: var(--color-text-muted);">
            Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.
          </p>
        </div>
        <div class="rounded-lg h-80 lg:h-96" style="background-color: var(--color-bg-subtle);"></div>
      </div>
    </div>
  </section>

  <!-- Types of Bankruptcy -->
  <section class="py-20 sm:py-28" style="background-color: var(--color-bg-subtle);">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block font-semibold text-sm uppercase tracking-wider mb-4" style="color: var(--color-accent);">Rodzaje</span>
        <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-6" style="color: var(--color-text);">
          Rodzaje postępowań upadłościowych
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Card 1 -->
        <div class="rounded-lg p-8 border" style="background-color: var(--color-bg); border-color: var(--color-text-muted);">
          <div class="w-12 h-12 rounded-md flex items-center justify-center mb-6" style="background-color: var(--color-accent);">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-text);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold mb-4" style="color: var(--color-text);">Upadłość przedsiębiorstwa</h3>
          <p class="leading-relaxed" style="color: var(--color-text-muted);">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="rounded-lg p-8 border" style="background-color: var(--color-bg); border-color: var(--color-text-muted);">
          <div class="w-12 h-12 rounded-md flex items-center justify-center mb-6" style="background-color: var(--color-accent);">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-text);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold mb-4" style="color: var(--color-text);">Upadłość konsumencka</h3>
          <p class="leading-relaxed" style="color: var(--color-text-muted);">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="rounded-lg p-8 border" style="background-color: var(--color-bg); border-color: var(--color-text-muted);">
          <div class="w-12 h-12 rounded-md flex items-center justify-center mb-6" style="background-color: var(--color-accent);">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-text);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold mb-4" style="color: var(--color-text);">Likwidacja majątku</h3>
          <p class="leading-relaxed" style="color: var(--color-text-muted);">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
          </p>
        </div>

        <!-- Card 4 -->
        <div class="rounded-lg p-8 border" style="background-color: var(--color-bg); border-color: var(--color-text-muted);">
          <div class="w-12 h-12 rounded-md flex items-center justify-center mb-6" style="background-color: var(--color-accent);">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-text);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold mb-4" style="color: var(--color-text);">Oddłużenie</h3>
          <p class="leading-relaxed" style="color: var(--color-text-muted);">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTASection variant="dark" />

</Layout>
