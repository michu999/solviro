---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="Kontakt — Solviro Legal" description="Skontaktuj się z nami. Umów bezpłatną konsultację w sprawie restrukturyzacji lub upadłości.">
  
  <PageHero
    title="Skontaktuj się z nami"
    description="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pierwsza konsultacja jest bezpłatna."
    breadcrumb={[
      { label: 'Strona główna', href: '/' },
      { label: 'Kontakt', href: '/kontakt' }
    ]}
  />

  <!-- Contact Section -->
  <section id="formularz" class="py-20 sm:py-28" style="background-color: var(--color-bg);">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <!-- Left Column - Contact Info -->
        <div>
          <h2 class="font-heading text-2xl sm:text-3xl font-bold mb-8" style="color: var(--color-text);">
            Dane kontaktowe
          </h2>

          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-md flex items-center justify-center flex-shrink-0" style="background-color: var(--color-bg-subtle);">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-lg font-semibold mb-2" style="color: var(--color-text);">Adres</h3>
                <p style="color: var(--color-text-muted);">
                  ul. Przykładowa 123<br />
                  00-001 Warszawa
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-md flex items-center justify-center flex-shrink-0" style="background-color: var(--color-bg-subtle);">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-lg font-semibold mb-2" style="color: var(--color-text);">Telefon</h3>
                <a href="tel:+48123456789" class="transition-colors duration-300" style="color: var(--color-text-muted);">
                  +48 123 456 789
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-md flex items-center justify-center flex-shrink-0" style="background-color: var(--color-bg-subtle);">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-lg font-semibold mb-2" style="color: var(--color-text);">E-mail</h3>
                <a href="mailto:kontakt@solviro.pl" class="transition-colors duration-300" style="color: var(--color-text-muted);">
                  kontakt@solviro.pl
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-md flex items-center justify-center flex-shrink-0" style="background-color: var(--color-bg-subtle);">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-lg font-semibold mb-2" style="color: var(--color-text);">Godziny pracy</h3>
                <p style="color: var(--color-text-muted);">
                  Poniedziałek – Piątek: 9:00 – 17:00<br />
                  Sobota – Niedziela: Zamknięte
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column - Form -->
        <div class="p-8 lg:p-10 rounded-lg" style="background-color: var(--color-bg-subtle);">
          <h2 class="font-heading text-2xl font-bold mb-6" style="color: var(--color-text);">
            Wyślij wiadomość
          </h2>
          <form id="contact-form" class="space-y-6">
            <div>
              <label for="name" class="block font-medium mb-2" style="color: var(--color-text);">
                Imię i nazwisko <span style="color: var(--color-accent);">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-md border outline-none transition-colors duration-300"
                style="border-color: var(--color-text-muted); background-color: var(--color-bg);"
                placeholder="Jan Kowalski"
              />
            </div>

            <div>
              <label for="email" class="block font-medium mb-2" style="color: var(--color-text);">
                Adres e-mail <span style="color: var(--color-accent);">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-md border outline-none transition-colors duration-300"
                style="border-color: var(--color-text-muted); background-color: var(--color-bg);"
                placeholder="jan@example.com"
              />
            </div>

            <div>
              <label for="phone" class="block font-medium mb-2" style="color: var(--color-text);">
                Numer telefonu <span style="color: var(--color-accent);">*</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full px-4 py-3 rounded-md border outline-none transition-colors duration-300"
                style="border-color: var(--color-text-muted); background-color: var(--color-bg);"
                placeholder="+48 123 456 789"
              />
            </div>

            <div>
              <label for="message" class="block font-medium mb-2" style="color: var(--color-text);">
                Wiadomość <span style="color: var(--color-accent);">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 rounded-md border outline-none transition-colors duration-300 resize-none"
                style="border-color: var(--color-text-muted); background-color: var(--color-bg);"
                placeholder="Opisz swoją sprawę..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full cta-button"
            >
              Wyślij wiadomość
            </button>

            <p class="text-sm text-center" style="color: var(--color-text-muted);">
              Wysyłając formularz, wyrażasz zgodę na przetwarzanie danych osobowych.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <CTASection variant="dark" />

</Layout>
