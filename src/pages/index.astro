---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="Solviro Legal — Restrukturyzacja i Upadłość | Kancelaria Prawna" description="Kancelaria specjalizująca się w restrukturyzacjach i upadłościach. Pomagamy firmom wyjść z kryzysu finansowego. Bezpłatna konsultacja.">

  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20" style="background-color: var(--color-bg-subtle);">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6" style="color: var(--color-text);">
          Twój Partner w<br />
          <span style="color: var(--color-accent);">Restrukturyzacji</span> i <span style="color: var(--color-accent);">Upadłości</span>
        </h1>
        <p class="text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed" style="color: var(--color-text-muted);">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Profesjonalne wsparcie prawne.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/kontakt#formularz"
            class="cta-button"
          >
            Umów bezpłatną konsultację
          </a>
          <a
            href="/o-nas"
            class="btn-secondary inline-flex items-center justify-center"
          >
            Poznaj nas
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-text-muted);">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- 3-Step Cooperation Process -->
  <section class="py-20 sm:py-28" style="background-color: var(--color-bg);">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block font-semibold text-sm uppercase tracking-wider mb-4" style="color: var(--color-accent);">Jak działamy</span>
        <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-6" style="color: var(--color-text);">
          Trzy kroki do rozwiązania
        </h2>
        <p class="text-lg leading-relaxed" style="color: var(--color-text-muted);">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Transparentność i jasna komunikacja to nasze priorytety.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Step 1 -->
        <div class="relative p-8 lg:p-10 rounded-lg" style="background-color: var(--color-bg-subtle);">
          <div class="w-16 h-16 rounded-md flex items-center justify-center mb-6" style="background-color: var(--color-cta-bg);">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-cta-text);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <span class="absolute top-8 right-8 font-heading text-6xl font-bold opacity-10" style="color: var(--color-text);">01</span>
          <h3 class="font-heading text-xl font-bold mb-4" style="color: var(--color-text);">Bezpłatna konsultacja</h3>
          <p class="leading-relaxed" style="color: var(--color-text-muted);">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="relative p-8 lg:p-10 rounded-lg" style="background-color: var(--color-bg-subtle);">
          <div class="w-16 h-16 rounded-md flex items-center justify-center mb-6" style="background-color: var(--color-cta-bg);">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-cta-text);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
          </div>
          <span class="absolute top-8 right-8 font-heading text-6xl font-bold opacity-10" style="color: var(--color-text);">02</span>
          <h3 class="font-heading text-xl font-bold mb-4" style="color: var(--color-text);">Analiza i strategia</h3>
          <p class="leading-relaxed" style="color: var(--color-text-muted);">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative p-8 lg:p-10 rounded-lg" style="background-color: var(--color-bg-subtle);">
          <div class="w-16 h-16 rounded-md flex items-center justify-center mb-6" style="background-color: var(--color-cta-bg);">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-cta-text);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <span class="absolute top-8 right-8 font-heading text-6xl font-bold opacity-10" style="color: var(--color-text);">03</span>
          <h3 class="font-heading text-xl font-bold mb-4" style="color: var(--color-text);">Prowadzenie postępowania</h3>
          <p class="leading-relaxed" style="color: var(--color-text-muted);">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid-page CTA Section -->
  <CTASection variant="light" />

  <!-- Services Section -->
  <section class="py-20 sm:py-28" style="background-color: var(--color-bg);">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block font-semibold text-sm uppercase tracking-wider mb-4" style="color: var(--color-accent);">Nasze usługi</span>
        <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-6" style="color: var(--color-text);">
          Specjalizacje
        </h2>
        <p class="text-lg leading-relaxed" style="color: var(--color-text-muted);">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Kompleksowe wsparcie prawne w zakresie restrukturyzacji i upadłości.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Restrukturyzacja Card -->
        <div class="group relative p-10 lg:p-12 rounded-lg border transition-colors duration-300" style="background-color: var(--color-bg); border-color: var(--color-text-muted);">
          <div class="relative z-10">
            <div class="w-14 h-14 rounded-md flex items-center justify-center mb-8" style="background-color: var(--color-cta-bg);">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-cta-text);">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <h3 class="font-heading text-2xl lg:text-3xl font-bold mb-4" style="color: var(--color-text);">Restrukturyzacja</h3>
            <p class="leading-relaxed mb-8" style="color: var(--color-text-muted);">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation.
            </p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-center gap-3" style="color: var(--color-text);">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Postępowanie o zatwierdzenie układu</span>
              </li>
              <li class="flex items-center gap-3" style="color: var(--color-text);">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Przyspieszone postępowanie układowe</span>
              </li>
              <li class="flex items-center gap-3" style="color: var(--color-text);">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Postępowanie sanacyjne</span>
              </li>
            </ul>
            <a
              href="/restrukturyzacja"
              class="inline-flex items-center gap-2 font-semibold hover:gap-4 transition-all duration-300"
              style="color: var(--color-text);"
            >
              Dowiedz się więcej
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Upadłość Card -->
        <div class="group relative p-10 lg:p-12 rounded-lg border transition-colors duration-300" style="background-color: var(--color-bg); border-color: var(--color-text-muted);">
          <div class="relative z-10">
            <div class="w-14 h-14 rounded-md flex items-center justify-center mb-8" style="background-color: var(--color-cta-bg);">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-cta-text);">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
              </svg>
            </div>
            <h3 class="font-heading text-2xl lg:text-3xl font-bold mb-4" style="color: var(--color-text);">Upadłość</h3>
            <p class="leading-relaxed mb-8" style="color: var(--color-text-muted);">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation.
            </p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-center gap-3" style="color: var(--color-text);">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Upadłość przedsiębiorstwa</span>
              </li>
              <li class="flex items-center gap-3" style="color: var(--color-text);">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Upadłość konsumencka</span>
              </li>
              <li class="flex items-center gap-3" style="color: var(--color-text);">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Likwidacja majątku</span>
              </li>
            </ul>
            <a
              href="/upadlosc"
              class="inline-flex items-center gap-2 font-semibold hover:gap-4 transition-all duration-300"
              style="color: var(--color-text);"
            >
              Dowiedz się więcej
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Studies Teaser -->
  <section class="py-20 sm:py-28" style="background-color: var(--color-bg-subtle);">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-16">
        <div>
          <span class="inline-block font-semibold text-sm uppercase tracking-wider mb-4" style="color: var(--color-accent);">Case Studies</span>
          <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold" style="color: var(--color-text);">
            Nasze realizacje
          </h2>
        </div>
        <a
          href="/case-studies"
          class="inline-flex items-center gap-2 font-semibold transition-colors duration-300"
          style="color: var(--color-text);"
        >
          Zobacz wszystkie
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Case Study Card 1 -->
        <article class="rounded-lg overflow-hidden hover:shadow-md transition-shadow duration-300" style="background-color: var(--color-bg);">
          <div class="h-48" style="background-color: var(--color-text-muted); opacity: 0.3;"></div>
          <div class="p-8">
            <span class="inline-block text-sm font-medium px-3 py-1 rounded-full mb-3" style="background-color: color-mix(in srgb, var(--color-accent) 20%, transparent); color: var(--color-primary);">
  Branża produkcyjna
</span>
            <h3 class="font-heading text-xl font-bold mb-3" style="color: var(--color-text);">
              Lorem Ipsum Dolor Sit Amet Consectetur
            </h3>
            <p class="text-sm leading-relaxed mb-6" style="color: var(--color-text-muted);">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore.
            </p>
            <div class="flex items-center justify-between pt-6 border-t" style="border-color: var(--color-text-muted); border-opacity: 0.2;">
              <span class="text-sm" style="color: var(--color-text-muted);">Redukcja długu o 65%</span>
              <a href="/case-studies/lorem-ipsum" class="font-semibold text-sm hover:underline" style="color: var(--color-accent);">
                Czytaj więcej
              </a>
            </div>
          </div>
        </article>

        <!-- Case Study Card 2 -->
        <article class="rounded-lg overflow-hidden hover:shadow-md transition-shadow duration-300" style="background-color: var(--color-bg);">
          <div class="h-48" style="background-color: var(--color-text-muted); opacity: 0.4;"></div>
          <div class="p-8">
            <span class="inline-block text-sm font-medium px-3 py-1 rounded-full mb-3" style="background-color: color-mix(in srgb, var(--color-accent) 20%, transparent); color: var(--color-primary);">
  Branża budowlana
</span>
            <h3 class="font-heading text-xl font-bold mb-3" style="color: var(--color-text);">
              Adipiscing Elit Sed Do Eiusmod Tempor
            </h3>
            <p class="text-sm leading-relaxed mb-6" style="color: var(--color-text-muted);">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore.
            </p>
            <div class="flex items-center justify-between pt-6 border-t" style="border-color: var(--color-text-muted); border-opacity: 0.2;">
              <span class="text-sm" style="color: var(--color-text-muted);">Układ zatwierdzony</span>
              <a href="/case-studies/adipiscing" class="font-semibold text-sm hover:underline" style="color: var(--color-accent);">
                Czytaj więcej
              </a>
            </div>
          </div>
        </article>

        <!-- Case Study Card 3 -->
        <article class="rounded-lg overflow-hidden hover:shadow-md transition-shadow duration-300 md:col-span-2 lg:col-span-1" style="background-color: var(--color-bg);">
          <div class="h-48" style="background-color: var(--color-text-muted); opacity: 0.5;"></div>
          <div class="p-8">
            <span class="inline-block text-sm font-medium px-3 py-1 rounded-full mb-3" style="background-color: color-mix(in srgb, var(--color-accent) 20%, transparent); color: var(--color-primary);">
  Handel detaliczny
</span>
            <h3 class="font-heading text-xl font-bold mb-3" style="color: var(--color-text);">
              Incididunt Ut Labore Et Dolore Magna
            </h3>
            <p class="text-sm leading-relaxed mb-6" style="color: var(--color-text-muted);">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore.
            </p>
            <div class="flex items-center justify-between pt-6 border-t" style="border-color: var(--color-text-muted); border-opacity: 0.2;">
              <span class="text-sm" style="color: var(--color-text-muted);">Firma uratowana</span>
              <a href="/case-studies/incididunt" class="font-semibold text-sm hover:underline" style="color: var(--color-accent);">
                Czytaj więcej
              </a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section id="formularz" class="py-20 sm:py-28" style="background-color: var(--color-primary);">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <!-- Left Column - Text -->
        <div>
          <span class="inline-block font-semibold text-sm uppercase tracking-wider mb-4" style="color: var(--color-accent);">Kontakt</span>
          <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold mb-6" style="color: var(--color-accent);">
            Porozmawiajmy o Twojej sprawie
          </h2>
          <p class="text-lg leading-relaxed mb-10" style="color: rgba(255,255,255,0.7);">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Pierwsza konsultacja jest bezpłatna.
          </p>

          <div class="space-y-6">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-md flex items-center justify-center flex-shrink-0" style="background-color: rgba(201,176,55,0.1);">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="text-sm mb-1" style="color: rgba(255,255,255,0.5);">Zadzwoń do nas</p>
                <a href="tel:+48123456789" class="font-semibold transition-colors duration-300" style="color: var(--color-accent);">
                  +48 123 456 789
                </a>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-md flex items-center justify-center flex-shrink-0" style="background-color: rgba(201,176,55,0.1);">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="text-sm mb-1" style="color: rgba(255,255,255,0.5);">Napisz do nas</p>
                <a href="mailto:kontakt@solviro.pl" class="font-semibold transition-colors duration-300" style="color: var(--color-accent);">
                  kontakt@solviro.pl
                </a>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-md flex items-center justify-center flex-shrink-0" style="background-color: rgba(201,176,55,0.1);">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent);">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm mb-1" style="color: rgba(255,255,255,0.5);">Odwiedź nas</p>
                <p class="font-semibold" style="color: var(--color-accent);">
                  ul. Przykładowa 123, 00-001 Warszawa
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column - Form -->
        <div class="p-8 lg:p-10 rounded-lg" style="background-color: var(--color-bg);">
          <form id="contact-form" class="space-y-6">
            <div>
              <label for="name" class="block font-medium mb-2" style="color: var(--color-text);">
                Imię i nazwisko <span style="color: var(--color-accent);">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-md border outline-none transition-colors duration-300"
                style="border-color: var(--color-text-muted); background-color: var(--color-bg);"
                placeholder="Jan Kowalski"
              />
            </div>

            <div>
              <label for="email" class="block font-medium mb-2" style="color: var(--color-text);">
                Adres e-mail <span style="color: var(--color-accent);">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-md border outline-none transition-colors duration-300"
                style="border-color: var(--color-text-muted); background-color: var(--color-bg);"
                placeholder="jan@example.com"
              />
            </div>

            <div>
              <label for="phone" class="block font-medium mb-2" style="color: var(--color-text);">
                Numer telefonu <span style="color: var(--color-accent);">*</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full px-4 py-3 rounded-md border outline-none transition-colors duration-300"
                style="border-color: var(--color-text-muted); background-color: var(--color-bg);"
                placeholder="+48 123 456 789"
              />
            </div>

            <div>
              <label for="message" class="block font-medium mb-2" style="color: var(--color-text);">
                Wiadomość <span style="color: var(--color-accent);">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 rounded-md border outline-none transition-colors duration-300 resize-none"
                style="border-color: var(--color-text-muted); background-color: var(--color-bg);"
                placeholder="Opisz swoją sprawę..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full cta-button"
            >
              Wyślij wiadomość
            </button>

            <p class="text-sm text-center" style="color: var(--color-text-muted);">
              Wysyłając formularz, wyrażasz zgodę na przetwarzanie danych osobowych.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

</Layout>
