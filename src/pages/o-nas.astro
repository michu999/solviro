      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Team Member 1 -->
        <div class="bg-gray-50 rounded-lg p-8">
          <div class="w-24 h-24 bg-gray-300 rounded-full mb-6"></div>
          <h3 class="font-heading text-xl font-bold text-black mb-2">Jan Kowalski</h3>
          <p class="text-gold font-medium mb-4">Radca Prawny, Partner</p>
