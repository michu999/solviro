<Layout title="O nas — Solviro Legal" description="Poznaj zespół Solviro Legal. Kancelaria specjalizująca się w restrukturyzacjach i upadłościach.">
  
  <!-- Hero Section -->
  <section class="pt-32 pb-20 bg-beige">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block text-gold font-semibold text-sm uppercase tracking-wider mb-4">O nas</span>
        <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold text-black leading-tight mb-6">
          Poznaj Solviro Legal
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 leading-relaxed">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
        </p>
      </div>
    </div>
  </section>

